<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crachá Virtual</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        /* Estrutura principal do crachá */
        .badge {
            background-color: #ffffff;
            width: 350px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            text-align: center;
            border-top: 8px solid #0056b3;
        }

        /* Cabeçalho com Logo */
        .badge-header {
            padding: 20px 20px 10px;
        }

        .badge-header h2 {
            color: #333;
            font-size: 1.2rem;
            margin-top: 5px;
        }

        /* Área da Foto */
        .badge-body {
            padding: 20px;
        }

        .avatar-container {
            width: 120px;
            height: 120px;
            margin: 0 auto 15px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid #0056b3;
            position: relative;
        }

        .avatar-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Informações do Usuário */
        .user-info h3 {
            color: #222;
            margin-bottom: 5px;
            font-size: 1.4rem;
        }

        .user-info p {
            color: #666;
            font-size: 0.95rem;
            margin-bottom: 3px;
        }

        .user-info .id-number {
            font-weight: bold;
            color: #0056b3;
            margin-top: 10px;
        }

        /* Área do QR Code / Autenticação */
        .badge-footer {
            background-color: #f8f9fa;
            padding: 15px;
            border-top: 1px solid #eee;
        }

        .qr-placeholder {
            width: 100px;
            height: 100px;
            margin: 0 auto 10px;
            display: block;
        }

        .status {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            background-color: #d4edda;
            color: #155724;
            font-size: 0.8rem;
            font-weight: bold;
        }

        /* Botão para trocar foto (Interação JavaScript) */
        .action-btn {
            margin-top: 15px;
            padding: 10px 20px;
            background-color: #0056b3;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }

        .action-btn:hover {
            background-color: #004085;
        }
    </style>
</head>
<body>

    <div class="badge">
        <div class="badge-header">
            <h2>Empresa Exemplo</h2>
        </div>
        
        <div class="badge-body">
            <div class="avatar-container">
                <img id="profileImage" src="https://placeholder.com" alt="Foto de Perfil">
            </div>
            
            <div class="user-info">
                <h3>Ana Silva</h3>
                <p>Desenvolvedora Front-End</p>
                <p class="id-number">ID: #40928</p>
            </div>

            <button class="action-btn" onclick="alterarFoto()">Alterar Foto</button>
        </div>

        <div class="badge-footer">
            <!-- Utiliza uma API pública do Google para gerar um QR Code dinâmico -->
            <img class="qr-placeholder" src="https://googleapis.com" alt="QR Code">
            <div class="status">Ativo</div>
        </div>
    </div>

    <script>
        // Função JavaScript para alterar a foto do crachá dinamicamente
        function alterarFoto() {
            // Exemplo de como solicitar uma nova imagem ao usuário e aplicar no crachá
            const novaUrl = prompt("Digite a URL da sua nova foto (ex: https://exemplo.com):");
            
            if (novaUrl && novaUrl.trim() !== "") {
                document.getElementById("profileImage").src = novaUrl;
            } else {
                alert("URL inválida ou cancelada.");
            }
        }
    </script>
</body>
</html>
